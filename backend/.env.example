# Base de dados.
# Local (corre já, sem instalar nada): SQLite
DATABASE_URL=sqlite:///./dev.db
# Local com Postgres via docker-compose (ver docker-compose.yml):
# DATABASE_URL=postgresql+psycopg://corrida:corrida@localhost:5432/corrida
# Produção (Render): usar a "Internal Database URL" do Render, trocando o
# prefixo para postgresql+psycopg:// se vier como postgres://

# Segurança JWT — TROCA por uma chave grande e aleatória em produção.
SECRET_KEY=troca-isto-por-uma-chave-grande-e-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Origens permitidas (CORS), separadas por vírgula.
CORS_ORIGINS=http://localhost:5173
